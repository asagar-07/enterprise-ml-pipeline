#--- Data & DVC files ---
#Ignore all data files and DVC files, but track .gitignore and .dvc files
data/raw/*
data/processed/*
data/features/*
!data/**/.gitignore
!data/**/*.dvc


#---MLFlow & Models---
#Ignore local experiment tracking and model artifacts, but track the registry
mlruns/
mlflow.db
models/
artifacts/
*.parquet
*joblib

# --Reports---
#Ignore generated reports
reports/evaluation/
reports/registry/
reports/data_transformation/

# --- Python and Environment ---
# Standard Python ignore patterns
__pycache__/
*.pyc
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
venv/
.env

# --- IDE & OS ---
.DS_Store
.vscode/
.idea/

# --- Research & Templates ---
# Ignore the setup script and the entire research scratchpad
project_template.py
research/
**/.ipynb_checkpoints

# --- Logs ---
#Ignore log files
logs/

